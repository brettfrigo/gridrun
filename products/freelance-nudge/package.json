{
  "name": "freelance-nudge",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n WEB,API \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "next dev -p 4173",
    "dev:server": "npm --prefix server run dev",
    "build": "next build",
    "start:web": "next start -p 4173",
    "start:server": "npm --prefix server start"
  },
  "dependencies": {
    "next": "15.2.2",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}